{
  "compileOnSave": false,
  "compilerOptions": {
    "importHelpers": true,
    "module": "es2020",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "target": "es2015",
    "skipLibCheck": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2017",
      "dom",
      "DOM.Iterable"
    ],
    "plugins": [
      { "name": "tslint-language-service"}
    ],
    "paths": {
      "exceljs": [
        "./node_modules/exceljs/dist/exceljs.min"
      ]
    }
  }
}
